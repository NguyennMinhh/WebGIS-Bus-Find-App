# =============================================================================
# DATABASE (PostgreSQL + PostGIS)
# =============================================================================
POSTGRES_DB=busrouting
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =============================================================================
# DJANGO BACKEND
# Tạo secret key mới: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# =============================================================================
DJANGO_SECRET_KEY=generate-a-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# =============================================================================
# GEOSERVER
# =============================================================================
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=your_geoserver_password_here

# =============================================================================
# FRONTEND (biến VITE_ được inject vào React lúc build)
# =============================================================================
VITE_API_URL=http://localhost:8000/api
VITE_GEOSERVER_URL=http://localhost:8600/geoserver
VITE_GEOSERVER_WORKSPACE=busrouting
